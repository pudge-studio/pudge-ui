---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/hero.css";
---

<BaseLayout title="404 — Not Found">
  <div class="site-main site-main--no-sidebar">
    <div class="site-content error-page">
      <div class="pudge-avatar-wrap error-page__avatar">
        <img src="/pudge/think.webp" alt="Pudge thinking" width="140" height="140" />
      </div>
      <div class="eyebrow">ERROR 404</div>
      <h1 class="error-page__title">Page Not Found</h1>
      <p class="error-page__text">
        Pudge couldn't find that page. It may have been moved or doesn't exist.
      </p>
      <div class="error-page__actions">
        <a href="/" class="btn-primary">Go Home</a>
        <a href="/components" class="btn-secondary">Browse Components</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    text-align: center;
    padding-top: var(--space-2xl);
  }

  .error-page__avatar {
    width: var(--avatar-xl);
    height: var(--avatar-xl);
    margin: 0 auto var(--space-lg);
  }

  .error-page__title {
    font-size: 2.5rem;
    margin-bottom: var(--space-sm);
  }

  .error-page__text {
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
    font-size: 1.1rem;
  }

  .error-page__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
  }
</style>
