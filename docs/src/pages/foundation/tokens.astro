---
import DocsLayout from "../../layouts/DocsLayout.astro";
import fs from "node:fs";
import path from "node:path";
import { renderSpec } from "@lib/spec";

const specRoot = path.resolve(process.cwd(), "..", "spec");
const raw = fs.readFileSync(path.join(specRoot, "foundation", "tokens.md"), "utf-8");
const html = await renderSpec(raw);

const breadcrumbs = [{ label: "Foundation", href: "/foundation" }, { label: "Tokens" }];

const surfaceColors = [
  { name: "--bg-base", dark: "#141210", light: "#f5f0e8", desc: "Workbench / desk surface" },
  { name: "--bg-raised", dark: "#1c1a18", light: "#ffffff", desc: "Device chassis top plate" },
  { name: "--bg-surface", dark: "#2a2826", light: "#f0ece4", desc: "Panel face" },
  { name: "--bg-inset", dark: "#0e0c0a", light: "#e8e4dc", desc: "Display cavity" },
  { name: "--bg-panel", dark: "#22201e", light: "#faf6ee", desc: "Button face" },
];

const accentColors = [
  { name: "--amber", value: "#f5a623", desc: "Primary active / selection" },
  { name: "--green-on", value: "#33cc66", desc: "Power-on / success" },
  { name: "--red-alert", value: "#cc2200", desc: "REC / error / critical" },
  { name: "--blue-info", value: "#4477cc", desc: "Info / consumer accent" },
  { name: "--pink-action", value: "#ee6688", desc: "Action accent" },
  { name: "--gold-warm", value: "#ddaa33", desc: "Premium / warm accent" },
];

const spacingScale = [
  { name: "--space-xs", value: "4px" },
  { name: "--space-sm", value: "8px" },
  { name: "--space-md", value: "14px" },
  { name: "--space-lg", value: "22px" },
  { name: "--space-xl", value: "36px" },
  { name: "--space-2xl", value: "56px" },
];

const radii = [
  { name: "--radius-sm", value: "4px" },
  { name: "--radius-md", value: "8px" },
  { name: "--radius-lg", value: "14px" },
  { name: "--radius-pill", value: "100px" },
  { name: "--radius-round", value: "50%" },
];
---

<DocsLayout
  title="Design Tokens"
  breadcrumbs={breadcrumbs}
  pudgePose="planner"
  pudgeMessage="Tokens are the DNA of the design system. Every visual decision traces back here."
>
  <h1>Design Tokens</h1>
  <p>All visual values in the system, defined as CSS custom properties.</p>

  <h2>Surface Colors</h2>
  <div class="swatch-grid">
    {
      surfaceColors.map((c) => (
        <div class="swatch">
          <div class="swatch__color" style={`background: ${c.dark};`} />
          <div class="swatch__info">
            <div class="swatch__name">{c.name}</div>
            <div class="swatch__value">
              {c.dark} / {c.light}
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <h2>Accent Colors</h2>
  <div class="swatch-grid">
    {
      accentColors.map((c) => (
        <div class="swatch">
          <div class="swatch__color" style={`background: ${c.value};`} />
          <div class="swatch__info">
            <div class="swatch__name">{c.name}</div>
            <div class="swatch__value">
              {c.value} — {c.desc}
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <h2>Spacing Scale</h2>
  <div class="spacing-scale">
    {
      spacingScale.map((s) => (
        <div class="spacing-item">
          <span class="spacing-item__label">{s.name}</span>
          <div class="spacing-item__bar" style={`width: ${s.value};`} />
          <span class="spacing-item__value">{s.value}</span>
        </div>
      ))
    }
  </div>

  <h2>Border Radius</h2>
  <div class="radius-grid">
    {
      radii.map((r) => (
        <div class="radius-item">
          <div class="radius-item__preview" style={`border-radius: ${r.value};`} />
          <div class="radius-item__label">{r.name}</div>
          <div class="radius-item__value">{r.value}</div>
        </div>
      ))
    }
  </div>

  <h2>Motion & Easing</h2>
  <div class="motion-grid">
    <div class="motion-item">
      <div class="motion-item__label">--snap-fast</div>
      <div class="motion-item__track">
        <div
          class="motion-item__bar"
          style="transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);"
        >
        </div>
      </div>
      <div class="motion-item__desc">Mechanical detent click</div>
    </div>
    <div class="motion-item">
      <div class="motion-item__label">--snap-soft</div>
      <div class="motion-item__track">
        <div
          class="motion-item__bar"
          style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
        >
        </div>
      </div>
      <div class="motion-item__desc">Drawer slide</div>
    </div>
    <div class="motion-item">
      <div class="motion-item__label">--ease-out</div>
      <div class="motion-item__track">
        <div
          class="motion-item__bar"
          style="transition-timing-function: cubic-bezier(0, 0, 0.2, 1);"
        >
        </div>
      </div>
      <div class="motion-item__desc">Smooth deceleration</div>
    </div>
    <div class="motion-item">
      <div class="motion-item__label">--spring</div>
      <div class="motion-item__track">
        <div
          class="motion-item__bar"
          style="transition-timing-function: cubic-bezier(0.34, 1.3, 0.64, 1);"
        >
        </div>
      </div>
      <div class="motion-item__desc">Spring-loaded mechanism</div>
    </div>
  </div>

  <hr />

  <div class="spec-content" set:html={html} />
</DocsLayout>
