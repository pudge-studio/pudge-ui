---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<span class:list={["new-badge", compact && "new-badge--compact"]} aria-label="New">NEW</span>

<style>
  .new-badge {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    font-family: var(--font-lcd);
    font-size: 0.72rem;
    letter-spacing: 2px;
    color: var(--green-on);
    background: color-mix(in srgb, var(--green-on) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--green-on) 35%, transparent);
    border-radius: 0;
    padding: 1px 5px 0;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--green-on) 12%, transparent),
      0 0 6px color-mix(in srgb, var(--green-on) 20%, transparent);
    animation: new-badge-pulse 2.4s steps(1) infinite;
    user-select: none;
    line-height: 1.4;
  }

  .new-badge--compact {
    font-size: 0.6rem;
    padding: 0 4px;
    letter-spacing: 1px;
  }

  @keyframes new-badge-pulse {
    0%   { opacity: 1;    box-shadow: 0 0 0 1px color-mix(in srgb, var(--green-on) 12%, transparent), 0 0 6px color-mix(in srgb, var(--green-on) 20%, transparent); }
    40%  { opacity: 0.55; box-shadow: 0 0 0 1px color-mix(in srgb, var(--green-on) 6%, transparent),  0 0 2px color-mix(in srgb, var(--green-on) 8%, transparent); }
    60%  { opacity: 1;    box-shadow: 0 0 0 1px color-mix(in srgb, var(--green-on) 12%, transparent), 0 0 6px color-mix(in srgb, var(--green-on) 20%, transparent); }
    100% { opacity: 1;    box-shadow: 0 0 0 1px color-mix(in srgb, var(--green-on) 12%, transparent), 0 0 6px color-mix(in srgb, var(--green-on) 20%, transparent); }
  }
</style>
