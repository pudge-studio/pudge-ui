---
import { changelog, BANNER_VERSION } from "../../data/changelog.js";

const latest = changelog[0];
const addedCount = latest.sections.added?.length ?? 0;
const addedItems = latest.sections.added ?? [];
---

<div class="version-banner" id="version-banner" data-version={BANNER_VERSION}>
  <button class="version-banner__body" type="button" id="version-banner-open" aria-label="See what's new in v{BANNER_VERSION}">
    <span class="version-banner__cursor">►</span>
    <span class="version-banner__tag">PUDGE/UI v{BANNER_VERSION}</span>
    <span class="version-banner__sep">—</span>
    <span class="version-banner__msg">{addedCount} additions this release</span>
    <span class="version-banner__cta">See what's new</span>
  </button>
  <button class="version-banner__dismiss" type="button" id="version-banner-dismiss" aria-label="Dismiss update notice">×</button>
</div>

<dialog class="version-dialog" id="version-dialog" aria-label="What's new in v{BANNER_VERSION}">
  <div class="version-dialog__inner">
    <div class="version-dialog__header">
      <span class="version-dialog__title">PUDGE/UI v{BANNER_VERSION}</span>
      <span class="version-dialog__date">{latest.date}</span>
      <button class="version-dialog__close" type="button" id="version-dialog-close" aria-label="Close">×</button>
    </div>

    <div class="version-dialog__scan-line" aria-hidden="true"></div>

    <div class="version-dialog__section">
      <div class="version-dialog__section-label">ADDED</div>
      <ul class="version-dialog__list">
        {addedItems.map((item) => (
          <li class="version-dialog__item">
            <span class="version-dialog__item-mark">+</span>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <div class="version-dialog__footer">
      <a href="/compositions" class="version-dialog__link">Compositions →</a>
      <a href="/changelog" class="version-dialog__link">Full Changelog →</a>
      <button class="version-dialog__dismiss-link" type="button" id="version-dialog-dismiss">Dismiss</button>
    </div>
  </div>
</dialog>

<style>
  /* Banner strip */
  .version-banner {
    position: fixed;
    top: var(--header-height, 60px);
    left: 0;
    right: 0;
    z-index: 90;
    height: 36px;
    display: flex;
    align-items: stretch;
    background: color-mix(in srgb, var(--green-on) 6%, var(--bg-inset));
    border-bottom: 1px solid color-mix(in srgb, var(--green-on) 30%, transparent);
    box-shadow: 0 1px 12px color-mix(in srgb, var(--green-on) 10%, transparent);
  }

  .version-banner__body {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 var(--space-lg);
    font-family: var(--font-lcd);
    font-size: 1rem;
    color: var(--green-on);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.12s;
    letter-spacing: 1px;
  }

  .version-banner__body:hover {
    background: color-mix(in srgb, var(--green-on) 8%, transparent);
  }

  .version-banner__cursor {
    font-size: 0.8rem;
    animation: banner-cursor 1.2s steps(1) infinite;
    flex-shrink: 0;
  }

  @keyframes banner-cursor {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  .version-banner__tag {
    font-weight: normal;
    opacity: 0.9;
    flex-shrink: 0;
  }

  .version-banner__sep {
    color: color-mix(in srgb, var(--green-on) 45%, transparent);
    flex-shrink: 0;
  }

  .version-banner__msg {
    color: color-mix(in srgb, var(--green-on) 75%, var(--text-secondary));
    flex-shrink: 0;
  }

  .version-banner__cta {
    color: var(--green-hi);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--green-on) 40%, transparent);
    font-size: 0.9rem;
  }

  .version-banner__dismiss {
    width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    border-left: 1px solid color-mix(in srgb, var(--green-on) 20%, transparent);
    color: color-mix(in srgb, var(--green-on) 55%, transparent);
    font-size: 1.2rem;
    cursor: pointer;
    transition: color 0.12s, background 0.12s;
    flex-shrink: 0;
    line-height: 1;
  }

  .version-banner__dismiss:hover {
    color: var(--green-on);
    background: color-mix(in srgb, var(--green-on) 10%, transparent);
  }

  @media (max-width: 600px) {
    .version-banner__cursor,
    .version-banner__tag,
    .version-banner__sep,
    .version-banner__cta {
      display: none;
    }

    .version-banner__body {
      padding: 0 var(--space-sm);
      font-size: 0.8rem;
    }
  }

  /* Dialog */
  .version-dialog {
    border: 1px solid color-mix(in srgb, var(--green-on) 40%, transparent);
    border-radius: 0;
    background: var(--bg-inset);
    padding: 0;
    width: min(520px, 92vw);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--green-on) 15%, transparent),
      0 8px 40px rgba(0, 0, 0, 0.7),
      0 0 60px color-mix(in srgb, var(--green-on) 6%, transparent);
    color: var(--green-on);
  }

  .version-dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(2px);
  }

  @media (max-width: 600px) {
    .version-dialog {
      width: 100vw;
      max-width: 100vw;
      height: 100dvh;
      max-height: 100dvh;
      margin: 0 !important;
      inset: 0;
      border-radius: 0;
      border-left: none;
      border-right: none;
      overflow-y: auto;
    }

    .version-dialog__inner {
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
    }

    .version-dialog__section {
      flex: 1;
    }
  }

  .version-dialog__inner {
    font-family: var(--font-lcd);
    font-size: 1rem;
    letter-spacing: 1px;
  }

  .version-dialog__header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 12px 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--green-on) 20%, transparent);
  }

  .version-dialog__title {
    font-size: 1.1rem;
    color: var(--green-hi);
  }

  .version-dialog__date {
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--green-on) 55%, transparent);
    margin-right: auto;
  }

  .version-dialog__close {
    background: none;
    border: none;
    color: color-mix(in srgb, var(--green-on) 55%, transparent);
    font-size: 1.4rem;
    cursor: pointer;
    line-height: 1;
    padding: 0 2px;
    transition: color 0.12s;
    font-family: var(--font-lcd);
  }

  .version-dialog__close:hover {
    color: var(--green-on);
  }

  .version-dialog__scan-line {
    height: 1px;
    background: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--green-on) 15%, transparent) 0,
      color-mix(in srgb, var(--green-on) 15%, transparent) 4px,
      transparent 4px,
      transparent 8px
    );
  }

  .version-dialog__section {
    padding: 16px;
  }

  .version-dialog__section-label {
    font-size: 0.75rem;
    letter-spacing: 3px;
    color: color-mix(in srgb, var(--green-on) 55%, transparent);
    margin-bottom: 10px;
  }

  .version-dialog__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .version-dialog__item {
    display: flex;
    gap: 10px;
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--green-on) 85%, var(--text-secondary));
    line-height: 1.5;
    letter-spacing: 0.5px;
  }

  .version-dialog__item-mark {
    color: var(--green-on);
    flex-shrink: 0;
    font-size: 1rem;
  }

  .version-dialog__footer {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 12px 16px;
    border-top: 1px solid color-mix(in srgb, var(--green-on) 20%, transparent);
    font-family: var(--font-lcd);
    font-size: 0.85rem;
  }

  .version-dialog__link {
    color: var(--green-on);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--green-on) 35%, transparent);
    transition: color 0.12s;
  }

  .version-dialog__link:hover {
    color: var(--green-hi);
  }

  .version-dialog__dismiss-link {
    margin-left: auto;
    background: none;
    border: none;
    color: color-mix(in srgb, var(--green-on) 45%, transparent);
    font-family: var(--font-lcd);
    font-size: 0.85rem;
    cursor: pointer;
    padding: 0;
    transition: color 0.12s;
    letter-spacing: 1px;
  }

  .version-dialog__dismiss-link:hover {
    color: var(--green-on);
  }
</style>

<script>
  const STORAGE_KEY = `pudge-banner-v${document.getElementById("version-banner")?.dataset.version}`;

  const banner = document.getElementById("version-banner");
  const dialog = document.getElementById("version-dialog") as HTMLDialogElement | null;
  const openBtn = document.getElementById("version-banner-open");
  const dismissBannerBtn = document.getElementById("version-banner-dismiss");
  const closeDialogBtn = document.getElementById("version-dialog-close");
  const dismissDialogBtn = document.getElementById("version-dialog-dismiss");

  function dismiss() {
    banner?.remove();
    try { localStorage.setItem(STORAGE_KEY, "1"); } catch {}
    document.documentElement.style.removeProperty("--banner-offset");
  }

  dismissBannerBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    dismiss();
  });

  openBtn?.addEventListener("click", () => {
    dialog?.showModal();
  });

  closeDialogBtn?.addEventListener("click", () => {
    dialog?.close();
  });

  dismissDialogBtn?.addEventListener("click", () => {
    dialog?.close();
    dismiss();
  });

  dialog?.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
