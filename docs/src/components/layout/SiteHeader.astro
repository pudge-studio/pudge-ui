---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navLinks = [
  { href: "/getting-started", label: "Docs", match: "/getting-started" },
  { href: "/components", label: "Components", match: "/components" },
  { href: "/foundation", label: "Foundation", match: "/foundation" },
  { href: "/guides/framework-integration", label: "Guides", match: "/guides" },
  { href: "/for-llms", label: "For LLMs", match: "/for-llms" },
];

const repoUrl = "https://github.com/pudge-studio/pudge-ui";
---

<header class="site-header">
  <a href="/" class="site-logo">
    <img
      src="/pudge-avatar.webp"
      alt="Pudge"
      width="28"
      height="28"
      class="site-logo__mark"
      decoding="async"
    />
    pudge<span class="site-logo__slash">/</span>ui
  </a>

  <button class="hamburger" type="button" data-toggle-mobile aria-label="Toggle menu">
    <svg
      width="18"
      height="18"
      viewBox="0 0 18 18"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path d="M3 5h12M3 9h12M3 13h12"></path>
    </svg>
  </button>

  <nav class="header-nav" aria-label="Main">
    {
      navLinks.map((link) =>
        link.external ? (
          <a href={link.href} class="header-nav__link" target="_blank" rel="noopener">
            {link.label}
          </a>
        ) : (
          <a
            href={link.href}
            class:list={["header-nav__link", currentPath.startsWith(link.match) && "is-active"]}
          >
            {link.label}
          </a>
        ),
      )
    }
  </nav>

  <button
    class="search-trigger"
    type="button"
    data-open-search
    aria-label="Search documentation"
    aria-keyshortcuts="/"
  >
    <svg
      width="14"
      height="14"
      viewBox="0 0 14 14"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      class="search-trigger__icon"
    >
      <circle cx="6" cy="6" r="4.5"></circle><path d="M9.5 9.5L13 13"></path>
    </svg>
    <span class="search-trigger__text">Search docs...</span>
    <span class="search-trigger__kbd"><kbd>/</kbd></span>
  </button>

  <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle theme">
    <span data-theme-icon>◐</span>
  </button>

  <a
    href={repoUrl}
    target="_blank"
    rel="noopener"
    class="header-star"
    aria-label="Star pudge-ui on GitHub"
    title="Star pudge-ui on GitHub"
  >
    <svg
      class="header-star__icon"
      width="15"
      height="15"
      viewBox="0 0 1024 1024"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        clip-rule="evenodd"
        d="M512 0C229.12 0 0 229.12 0 512c0 226.56 146.56 417.92 350.08 485.76 25.6 4.48 35.2-10.88 35.2-24.32 0-12.16-.64-52.48-.64-95.36-128.64 23.68-161.92-31.36-172.16-60.16-5.76-14.72-30.72-60.16-52.48-72.32-17.92-9.6-43.52-33.28-.64-33.92 40.32-.64 69.12 37.12 78.72 52.48 46.08 77.44 119.68 55.68 149.12 42.24 4.48-33.28 17.92-55.68 32.64-68.48-113.92-12.8-232.96-56.96-232.96-252.8 0-55.68 19.84-101.76 52.48-137.6-5.12-12.8-23.04-65.28 5.12-135.68 0 0 42.88-13.44 140.8 52.48 40.96-11.52 84.48-17.28 128-17.28s87.04 5.76 128 17.28c97.92-66.56 140.8-52.48 140.8-52.48 28.16 70.4 10.24 122.88 5.12 135.68 32.64 35.84 52.48 81.28 52.48 137.6 0 196.48-119.68 240-233.6 252.8 18.56 16 34.56 46.72 34.56 94.72 0 68.48-.64 123.52-.64 140.8 0 13.44 9.6 29.44 35.2 24.32C877.44 929.92 1024 737.92 1024 512 1024 229.12 794.88 0 512 0"
      ></path>
    </svg>
    <span class="header-star__text">Star</span>
    <span class="header-star__count" data-star-count hidden></span>
  </a>
</header>

<script>
  // Live GitHub star count, cached in localStorage to stay under the
  // unauthenticated API rate limit (60/hr/IP).
  const el = document.querySelector<HTMLElement>("[data-star-count]");
  if (el) {
    const CACHE_KEY = "pudge-star-count";
    const TTL = 6 * 60 * 60 * 1000; // 6h
    const fmt = (n: number) =>
      n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, "") + "k" : String(n);
    const show = (n: unknown) => {
      // Only surface a count once there's at least one star — "Star 0" reads sad.
      if (typeof n === "number" && n > 0) {
        el.textContent = fmt(n);
        el.hidden = false;
      }
    };

    let cached: { count: number; ts: number } | null = null;
    try {
      cached = JSON.parse(localStorage.getItem(CACHE_KEY) || "null");
    } catch {
      cached = null;
    }

    if (cached && Date.now() - cached.ts < TTL) {
      show(cached.count);
    } else {
      fetch("https://api.github.com/repos/pudge-studio/pudge-ui")
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          if (d && typeof d.stargazers_count === "number") {
            show(d.stargazers_count);
            try {
              localStorage.setItem(
                CACHE_KEY,
                JSON.stringify({ count: d.stargazers_count, ts: Date.now() }),
              );
            } catch {
              /* ignore quota / privacy-mode errors */
            }
          }
        })
        .catch(() => {
          /* offline or rate-limited — button still works without a count */
        });
    }
  }
</script>
